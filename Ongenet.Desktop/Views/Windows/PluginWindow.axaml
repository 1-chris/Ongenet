<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Ongenet.Desktop.Views.Windows.PluginWindow"
        Width="500" Height="360" MinWidth="200" MinHeight="120"
        CanResize="True"
        Background="{StaticResource CatppuccinBase}"
        Title="Plugin">
    <!-- Intentionally empty: the CLAP plugin embeds its native GUI into this window's surface. -->
    <Panel Background="{StaticResource CatppuccinBase}"/>
</Window>
