<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:Ongenet.Desktop.ViewModels"
        xmlns:th="using:Ongenet.Desktop.Theming"
        mc:Ignorable="d" d:DesignWidth="420" d:DesignHeight="640"
        x:Class="Ongenet.Desktop.Views.Windows.ThemeWindow"
        x:DataType="vm:ThemeEditorViewModel"
        Width="420" Height="640" MinWidth="360" MinHeight="400"
        Title="Theme"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        SystemDecorations="None"
        ExtendClientAreaToDecorationsHint="True">
    <Window.Styles>
        <Style Selector="Button.Action">
            <Setter Property="Background" Value="{StaticResource CatppuccinSurface0}"/>
            <Setter Property="Foreground" Value="{StaticResource CatppuccinText}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style Selector="Button.Action:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource CatppuccinSurface1}"/>
        </Style>
    </Window.Styles>

    <Panel>
    <Border Background="{StaticResource CatppuccinBase}" BorderBrush="{StaticResource CatppuccinBase}"
            BorderThickness="1" CornerRadius="8" ClipToBounds="True">
        <Grid RowDefinitions="Auto, *">
            <!-- Custom title bar -->
            <Grid Grid.Row="0" Name="TitleBar" Classes="TitleBar" ColumnDefinitions="Auto, *, Auto"
                  PointerPressed="TitleBar_PointerPressed">
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                    <TextBlock Text="Theme" FontSize="12" Foreground="{StaticResource CatppuccinOverlay2}" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Name="CloseButton" Classes="TitleBarButton Close" Click="CloseButton_Click">
                        <Path VerticalAlignment="Center" HorizontalAlignment="Center" Data="M0,0 L10,10 M10,0 L0,10"
                              Stroke="{Binding $parent[Button].Foreground}" StrokeThickness="1"/>
                    </Button>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" RowDefinitions="Auto, Auto, *" Margin="15">
                <!-- Built-in flavour + variant -->
                <StackPanel Grid.Row="0" Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="Preset" VerticalAlignment="Center" Width="60"
                                   Foreground="{StaticResource CatppuccinSubtext1}"/>
                        <ComboBox Width="200" ItemsSource="{Binding BuiltIns}"
                                  SelectedItem="{Binding SelectedBuiltIn, Mode=TwoWay}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="th:ThemeDefinition">
                                    <TextBlock Text="{Binding Name}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="Variant" VerticalAlignment="Center" Width="60"
                                   Foreground="{StaticResource CatppuccinSubtext1}"/>
                        <ToggleSwitch IsChecked="{Binding IsLight, Mode=TwoWay}" OnContent="Light" OffContent="Dark"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,4,0,0">
                        <Button Content="Import JSON…" Classes="Action" Click="Import_Click"/>
                        <Button Content="Export JSON…" Classes="Action" Click="Export_Click"/>
                    </StackPanel>
                </StackPanel>

                <Border Grid.Row="1" Height="1" Background="{StaticResource CatppuccinSurface0}" Margin="0,12"/>

                <!-- Per-token colour editor -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Tokens}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ThemeTokenRow">
                                <Grid ColumnDefinitions="Auto, *, 110" Margin="0,3">
                                    <Border Grid.Column="0" Width="22" Height="22" CornerRadius="4"
                                            Background="{Binding Swatch}"
                                            BorderBrush="{StaticResource CatppuccinSurface2}" BorderThickness="1"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Token}" VerticalAlignment="Center"
                                               Margin="10,0" Foreground="{StaticResource CatppuccinText}"/>
                                    <TextBox Grid.Column="2" Text="{Binding Hex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             FontFamily="DejaVu Sans Mono, Monospace" FontSize="12"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>

    <!-- Resize handles -->
    <Grid IsHitTestVisible="True">
        <Border Width="4" HorizontalAlignment="Left" Cursor="LeftSide" PointerPressed="OnResizeHandlePressed" Tag="Left" Background="Transparent"/>
        <Border Width="4" HorizontalAlignment="Right" Cursor="RightSide" PointerPressed="OnResizeHandlePressed" Tag="Right" Background="Transparent"/>
        <Border Height="4" VerticalAlignment="Top" Cursor="TopSide" PointerPressed="OnResizeHandlePressed" Tag="Top" Background="Transparent"/>
        <Border Height="4" VerticalAlignment="Bottom" Cursor="BottomSide" PointerPressed="OnResizeHandlePressed" Tag="Bottom" Background="Transparent"/>
        <Border Width="8" Height="8" HorizontalAlignment="Left" VerticalAlignment="Top" Cursor="TopLeftCorner" PointerPressed="OnResizeHandlePressed" Tag="TopLeft" Background="Transparent"/>
        <Border Width="8" Height="8" HorizontalAlignment="Right" VerticalAlignment="Top" Cursor="TopRightCorner" PointerPressed="OnResizeHandlePressed" Tag="TopRight" Background="Transparent"/>
        <Border Width="8" Height="8" HorizontalAlignment="Left" VerticalAlignment="Bottom" Cursor="BottomLeftCorner" PointerPressed="OnResizeHandlePressed" Tag="BottomLeft" Background="Transparent"/>
        <Border Width="8" Height="8" HorizontalAlignment="Right" VerticalAlignment="Bottom" Cursor="BottomRightCorner" PointerPressed="OnResizeHandlePressed" Tag="BottomRight" Background="Transparent"/>
    </Grid>
    </Panel>
</Window>
