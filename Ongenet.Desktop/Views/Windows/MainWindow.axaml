<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:Ongenet.Desktop.ViewModels"
        xmlns:views="using:Ongenet.Desktop.Views.Panels"
        xmlns:controls="using:Ongenet.Desktop.Controls"
        xmlns:conv="using:Ongenet.Desktop.Converters"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Ongenet.Desktop.Views.Windows.MainWindow"
        x:DataType="vm:MainViewModel"
        Width="1670" Height="900"
        TransparencyLevelHint="Blur, AcrylicBlur, Transparent"
        Background="Transparent"
        SystemDecorations="None"
        ExtendClientAreaToDecorationsHint="True"
        Title="{Binding Title}">

    <Window.Resources>
        <!-- Remove the Fluent active-tab accent "pipe" (the underline) — selection is shown by colour. -->
        <SolidColorBrush x:Key="TabItemHeaderSelectedPipeFill" Color="Transparent"/>
    </Window.Resources>

    <Window.Styles>
        <!-- Compact, distinct tab headers for the bottom (Instrument/Piano Roll/Effects) and right-side
             (Files/Instruments) panels: normal-size font on a lighter strip than the panel content. -->
        <Style Selector="TabItem">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Background" Value="{StaticResource CatppuccinSurface0}"/>
            <Setter Property="Foreground" Value="{StaticResource CatppuccinSubtext0}"/>
        </Style>
        <Style Selector="TabItem:pointerover">
            <Setter Property="Background" Value="{StaticResource CatppuccinSurface1}"/>
        </Style>
        <Style Selector="TabItem:selected">
            <Setter Property="Background" Value="{StaticResource CatppuccinSurface1}"/>
            <Setter Property="Foreground" Value="{StaticResource CatppuccinText}"/>
        </Style>
    </Window.Styles>

    <Panel>
    <Border Name="RootBorder" Background="{StaticResource CatppuccinBase}" BorderBrush="{StaticResource CatppuccinBase}" BorderThickness="1" CornerRadius="8" ClipToBounds="True">
    <Panel>
        <Grid RowDefinitions="Auto, *">
            <!-- Custom Title Bar (exact port of the original MainWindow chrome) -->
            <Grid Grid.Row="0" Name="TitleBar" Classes="TitleBar" ColumnDefinitions="Auto, *, Auto" PointerPressed="TitleBar_PointerPressed">
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <!-- macOS "traffic light" buttons live on the left; hidden on other platforms (toggled in code-behind).
                     macOS left-to-right order: close (red) / minimise (yellow) / maximise (green). -->
                <StackPanel Name="MacWindowButtons" Orientation="Horizontal" Spacing="8"
                            VerticalAlignment="Center" Margin="14,0,8,0" IsVisible="False">
                    <Button Classes="MacButton" Background="{StaticResource CatppuccinRed}"
                            Click="CloseButton_Click" ToolTip.Tip="Close">
                        <Path Data="M0,0 L7,7 M7,0 L0,7" Stroke="#80000000" StrokeThickness="1.2" Opacity="0"
                              VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>
                    <Button Classes="MacButton" Background="{StaticResource CatppuccinYellow}"
                            Click="MinimizeButton_Click" ToolTip.Tip="Minimize">
                        <Path Data="M0,3 L7,3" Stroke="#80000000" StrokeThickness="1.2" Opacity="0"
                              VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>
                    <Button Classes="MacButton" Background="{StaticResource CatppuccinGreen}"
                            Click="MaximizeButton_Click" ToolTip.Tip="Maximize">
                        <Path Data="M0,3 L7,3 M3.5,0 L3.5,7" Stroke="#80000000" StrokeThickness="1.2" Opacity="0"
                              VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>
                </StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0" Spacing="12">
                    <TextBlock Text="Ongenet" FontSize="12" Foreground="{StaticResource CatppuccinMauve}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Version}" FontSize="10" Foreground="{StaticResource CatppuccinOverlay1}"
                               VerticalAlignment="Center" Margin="-6,1,0,0"/>
                    <Button Content="New" Click="OnNew_Click" FontSize="11" Padding="8,2"
                            Background="Transparent" Foreground="{StaticResource CatppuccinSubtext0}"
                            ToolTip.Tip="New project (Ctrl+N)"/>
                    <Button Content="Open" Click="OnOpen_Click" FontSize="11" Padding="8,2"
                            Background="Transparent" Foreground="{StaticResource CatppuccinSubtext0}"
                            ToolTip.Tip="Open project (Ctrl+O)"/>
                    <Button Content="Save" Click="OnSave_Click" FontSize="11" Padding="8,2"
                            Background="Transparent" Foreground="{StaticResource CatppuccinSubtext0}"
                            ToolTip.Tip="Save project (Ctrl+S)"/>
                    <Button Content="Save As" Click="OnSaveAs_Click" FontSize="11" Padding="8,2"
                            Background="Transparent" Foreground="{StaticResource CatppuccinSubtext0}"
                            ToolTip.Tip="Save project as… (Ctrl+Shift+S)"/>
                    <Button Content="↶" Click="OnUndo_Click" FontSize="13" Padding="8,2"
                            IsEnabled="{Binding CanUndo}"
                            Background="Transparent" Foreground="{StaticResource CatppuccinSubtext0}"
                            ToolTip.Tip="Undo (Ctrl+Z)"/>
                    <Button Content="↷" Click="OnRedo_Click" FontSize="13" Padding="8,2"
                            IsEnabled="{Binding CanRedo}"
                            Background="Transparent" Foreground="{StaticResource CatppuccinSubtext0}"
                            ToolTip.Tip="Redo (Ctrl+Y)"/>
                    <Button Content="History" Click="OpenHistory_Click" FontSize="11" Padding="8,2"
                            Background="Transparent" Foreground="{StaticResource CatppuccinSubtext0}"
                            ToolTip.Tip="History"/>
                    <Button Content="Logs" Click="OpenLogs_Click" FontSize="11" Padding="8,2"
                            Background="Transparent" Foreground="{StaticResource CatppuccinSubtext0}"/>
                    <Button Content="Settings" Click="OpenSettings_Click" FontSize="11" Padding="8,2"
                            Background="Transparent" Foreground="{StaticResource CatppuccinSubtext0}"
                            ToolTip.Tip="Settings (audio, MIDI, theme)"/>
                    <!-- Save/Load progress indicator -->
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center"
                                IsVisible="{Binding IsBusy}">
                        <ProgressBar IsIndeterminate="True" Width="70" Height="4" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding BusyStatus}" FontSize="11" VerticalAlignment="Center"
                                   Foreground="{StaticResource CatppuccinGreen}"/>
                    </StackPanel>
                </StackPanel>
                </StackPanel>
                <StackPanel Name="StandardWindowButtons" Grid.Column="2" Orientation="Horizontal">
                    <Button Name="MinimizeButton" Classes="TitleBarButton" Click="MinimizeButton_Click">
                        <Path Margin="0,5,0,0" VerticalAlignment="Center" HorizontalAlignment="Center" Data="M0,0 L10,0" Stroke="{Binding $parent[Button].Foreground}" StrokeThickness="1"/>
                    </Button>
                    <Button Name="MaximizeButton" Classes="TitleBarButton" Click="MaximizeButton_Click">
                        <Path VerticalAlignment="Center" HorizontalAlignment="Center" Data="M0,0 L10,0 L10,10 L0,10 Z" Stroke="{Binding $parent[Button].Foreground}" StrokeThickness="1" Fill="Transparent"/>
                    </Button>
                    <Button Name="CloseButton" Classes="TitleBarButton Close" Click="CloseButton_Click">
                        <Path VerticalAlignment="Center" HorizontalAlignment="Center" Data="M0,0 L10,10 M10,0 L0,10" Stroke="{Binding $parent[Button].Foreground}" StrokeThickness="1"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- DAW workspace: transport bar over [track inspector | timeline+clip inspector | file browser] -->
            <Grid Grid.Row="1" RowDefinitions="Auto,*">

                <views:TransportView Grid.Row="0" DataContext="{Binding Transport}"/>

                <Grid Grid.Row="1" Name="WorkspaceGrid">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="240"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="260"/>
                    </Grid.ColumnDefinitions>
                    <!-- Top row holds the sidebars + timeline; the bottom panel spans the full width below -->
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="4"/>
                        <RowDefinition Height="432"/>
                    </Grid.RowDefinitions>

                    <!-- Left: track settings (collapsible) -->
                    <Grid Grid.Column="0" Grid.Row="0" RowDefinitions="Auto,*" Background="{StaticResource CatppuccinMantle}">
                        <Border Grid.Row="0" Height="26" Background="{StaticResource CatppuccinSurface0}">
                            <Button Name="LeftToggle" Content="◂" Click="ToggleLeftPanel"
                                    HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Background="Transparent" Padding="8,0" FontSize="11"
                                    Foreground="{StaticResource CatppuccinSubtext0}"
                                    ToolTip.Tip="Collapse / expand panel"/>
                        </Border>
                        <views:TrackInspectorView Grid.Row="1" Name="LeftContent" MinWidth="180"
                                                  DataContext="{Binding TrackInspector}"/>
                    </Grid>
                    <GridSplitter Grid.Column="1" Grid.Row="0" Name="LeftSplitter" ResizeDirection="Columns"
                                  Background="{StaticResource CatppuccinCrust}"/>

                    <!-- Centre: timeline (the bottom panel spans the full width below, see further down) -->
                    <views:TimelineView Grid.Column="2" Grid.Row="0" DataContext="{Binding Timeline}"/>

                    <GridSplitter Grid.Column="3" Grid.Row="0" Grid.RowSpan="3" Name="RightSplitter" ResizeDirection="Columns"
                                  Background="{StaticResource CatppuccinCrust}"/>

                    <!-- Right: tabbed Files / Instruments with sideways tabs (collapsible to just the tabs) -->
                    <!-- Right sidebar: [collapse toggle + sideways tab strip] | [selected panel + preview].
                         Collapsing hides the whole RightContent column so the Auto-sized outer column
                         shrinks to just the strip. -->
                    <Grid Grid.Column="4" Grid.Row="0" Grid.RowSpan="3" ColumnDefinitions="Auto,*" Background="{StaticResource CatppuccinMantle}">
                        <DockPanel Grid.Column="0" Background="{StaticResource CatppuccinSurface0}">
                            <Border DockPanel.Dock="Top" Height="26">
                                <Button Name="RightToggle" Content="▸" Click="ToggleRightPanel"
                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Width="24" Padding="0" FontSize="11"
                                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                        Background="Transparent"
                                        Foreground="{StaticResource CatppuccinSubtext0}"
                                        ToolTip.Tip="Collapse / expand panel"/>
                            </Border>
                            <!-- Custom vertical tab strip: a fully-templated ListBox of rotated labels so we
                                 control the centring ourselves. -->
                            <ListBox Name="RightTabStrip" SelectedIndex="0" FontSize="12"
                                     Background="Transparent" BorderThickness="0" Padding="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.Styles>
                                    <Style Selector="ListBoxItem">
                                        <Setter Property="Padding" Value="3,10"/>
                                        <Setter Property="MinHeight" Value="0"/>
                                        <Setter Property="CornerRadius" Value="0"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="{StaticResource CatppuccinSubtext0}"/>
                                    </Style>
                                    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                                        <Setter Property="Background" Value="{StaticResource CatppuccinSurface1}"/>
                                    </Style>
                                    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                                        <Setter Property="Background" Value="{StaticResource CatppuccinSurface1}"/>
                                    </Style>
                                    <Style Selector="ListBoxItem:selected">
                                        <Setter Property="Foreground" Value="{StaticResource CatppuccinText}"/>
                                    </Style>
                                </ListBox.Styles>
                                <ListBoxItem Name="TabEverything"><controls:VerticalTabLabel Text="Everything" Foreground="{Binding $parent[ListBoxItem].Foreground}"/></ListBoxItem>
                                <ListBoxItem Name="TabFiles"><controls:VerticalTabLabel Text="Files" Foreground="{Binding $parent[ListBoxItem].Foreground}"/></ListBoxItem>
                                <ListBoxItem Name="TabSamples"><controls:VerticalTabLabel Text="Samples" Foreground="{Binding $parent[ListBoxItem].Foreground}"/></ListBoxItem>
                                <ListBoxItem Name="TabSoundfonts"><controls:VerticalTabLabel Text="Soundfonts" Foreground="{Binding $parent[ListBoxItem].Foreground}"/></ListBoxItem>
                                <ListBoxItem Name="TabInstruments"><controls:VerticalTabLabel Text="Instruments" Foreground="{Binding $parent[ListBoxItem].Foreground}"/></ListBoxItem>
                                <ListBoxItem Name="TabEffects"><controls:VerticalTabLabel Text="Effects" Foreground="{Binding $parent[ListBoxItem].Foreground}"/></ListBoxItem>
                                <ListBoxItem Name="TabInstPresets"><controls:VerticalTabLabel Text="Inst Presets" Foreground="{Binding $parent[ListBoxItem].Foreground}"/></ListBoxItem>
                                <ListBoxItem Name="TabFxPresets"><controls:VerticalTabLabel Text="FX Presets" Foreground="{Binding $parent[ListBoxItem].Foreground}"/></ListBoxItem>
                                <ListBoxItem Name="TabFxChains"><controls:VerticalTabLabel Text="FX Chains" Foreground="{Binding $parent[ListBoxItem].Foreground}"/></ListBoxItem>
                            </ListBox>
                        </DockPanel>

                        <DockPanel Grid.Column="1" Name="RightContent" MinWidth="180"
                                   Background="{StaticResource CatppuccinMantle}">
                            <!-- Sample-tab options: always visible on Everything/Files/Samples, even with nothing selected -->
                            <views:LibraryOptionsView DockPanel.Dock="Bottom" DataContext="{Binding LibraryOptions}">
                                <views:LibraryOptionsView.IsVisible>
                                    <MultiBinding Converter="{x:Static conv:AnyTrueConverter.Instance}">
                                        <Binding ElementName="TabEverything" Path="IsSelected"/>
                                        <Binding ElementName="TabFiles" Path="IsSelected"/>
                                        <Binding ElementName="TabSamples" Path="IsSelected"/>
                                    </MultiBinding>
                                </views:LibraryOptionsView.IsVisible>
                            </views:LibraryOptionsView>
                            <views:PreviewPanelView DockPanel.Dock="Bottom" DataContext="{Binding Preview}"/>
                            <Grid>
                                <views:LibraryListView IsVisible="{Binding #TabEverything.IsSelected}" DataContext="{Binding Everything}"/>
                                <views:FileBrowserView IsVisible="{Binding #TabFiles.IsSelected}" DataContext="{Binding FileBrowser}"/>
                                <views:LibraryListView IsVisible="{Binding #TabSamples.IsSelected}" DataContext="{Binding SampleLibrary}"/>
                                <views:LibraryListView IsVisible="{Binding #TabSoundfonts.IsSelected}" DataContext="{Binding SoundFontLibrary}"/>
                                <views:LibraryListView IsVisible="{Binding #TabInstruments.IsSelected}" DataContext="{Binding InstrumentLibrary}"/>
                                <views:LibraryListView IsVisible="{Binding #TabEffects.IsSelected}" DataContext="{Binding EffectsLibrary}"/>
                                <views:LibraryListView IsVisible="{Binding #TabInstPresets.IsSelected}" DataContext="{Binding InstrumentPresets}"/>
                                <views:LibraryListView IsVisible="{Binding #TabFxPresets.IsSelected}" DataContext="{Binding EffectPresets}"/>
                                <views:LibraryListView IsVisible="{Binding #TabFxChains.IsSelected}" DataContext="{Binding EffectChainPresets}"/>
                            </Grid>
                        </DockPanel>
                    </Grid>

                    <!-- Bottom panel spans from the left edge across to the right splitter -->
                    <GridSplitter Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Name="BottomSplitter"
                                  ResizeDirection="Rows" HorizontalAlignment="Stretch"
                                  Background="{StaticResource CatppuccinCrust}"/>
                    <!-- Bottom panel: tabbed Instrument / Piano Roll / Effects (collapsible to just the tabs) -->
                    <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3">
                        <TabControl Name="BottomTabs" MinHeight="0" DataContext="{Binding BottomPanel}"
                                    SelectedIndex="{Binding SelectedTabIndex}"
                                    Background="{StaticResource CatppuccinMantle}">
                            <!-- Contextual first tab: Instrument inspector, or Sample inspector for an audio clip -->
                            <TabItem Header="{Binding FirstTabHeader}" IsVisible="{Binding ShowFirstTab}">
                                <Panel Name="BottomFirstContent">
                                    <ContentControl IsVisible="{Binding IsInstrumentMode}">
                                        <views:InstrumentInspectorView DataContext="{Binding Instrument}"/>
                                    </ContentControl>
                                    <ContentControl IsVisible="{Binding IsSampleSelected}">
                                        <views:SampleInspectorView DataContext="{Binding Sample}"/>
                                    </ContentControl>
                                </Panel>
                            </TabItem>
                            <TabItem Header="Piano Roll" IsVisible="{Binding ShowPianoRollTab}">
                                <views:PianoRollView Name="BottomPianoContent" DataContext="{Binding PianoRoll}"/>
                            </TabItem>
                            <TabItem Header="Effects">
                                <views:EffectsView Name="BottomEffectsContent" DataContext="{Binding Effects}"/>
                            </TabItem>
                        </TabControl>
                        <Button Name="BottomToggle" Content="▾" Click="ToggleBottomPanel"
                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                Background="Transparent" Padding="10,4" FontSize="11"
                                Foreground="{StaticResource CatppuccinSubtext0}"
                                ToolTip.Tip="Collapse / expand panel"/>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Panel>
    </Border>

    <!-- Resize Handles -->
    <Grid IsHitTestVisible="True">
        <Border Width="4" HorizontalAlignment="Left" Cursor="LeftSide" PointerPressed="OnResizeHandlePressed" Tag="Left" Background="Transparent"/>
        <Border Width="4" HorizontalAlignment="Right" Cursor="RightSide" PointerPressed="OnResizeHandlePressed" Tag="Right" Background="Transparent"/>
        <Border Height="4" VerticalAlignment="Top" Cursor="TopSide" PointerPressed="OnResizeHandlePressed" Tag="Top" Background="Transparent"/>
        <Border Height="4" VerticalAlignment="Bottom" Cursor="BottomSide" PointerPressed="OnResizeHandlePressed" Tag="Bottom" Background="Transparent"/>
        <Border Width="8" Height="8" HorizontalAlignment="Left" VerticalAlignment="Top" Cursor="TopLeftCorner" PointerPressed="OnResizeHandlePressed" Tag="TopLeft" Background="Transparent"/>
        <Border Width="8" Height="8" HorizontalAlignment="Right" VerticalAlignment="Top" Cursor="TopRightCorner" PointerPressed="OnResizeHandlePressed" Tag="TopRight" Background="Transparent"/>
        <Border Width="8" Height="8" HorizontalAlignment="Left" VerticalAlignment="Bottom" Cursor="BottomLeftCorner" PointerPressed="OnResizeHandlePressed" Tag="BottomLeft" Background="Transparent"/>
        <Border Width="8" Height="8" HorizontalAlignment="Right" VerticalAlignment="Bottom" Cursor="BottomRightCorner" PointerPressed="OnResizeHandlePressed" Tag="BottomRight" Background="Transparent"/>
    </Grid>
    </Panel>
</Window>
