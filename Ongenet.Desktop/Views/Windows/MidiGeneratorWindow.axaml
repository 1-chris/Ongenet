<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:Ongenet.Desktop.ViewModels"
        mc:Ignorable="d" d:DesignWidth="320" d:DesignHeight="420"
        x:Class="Ongenet.Desktop.Views.Windows.MidiGeneratorWindow"
        x:DataType="vm:MidiGeneratorViewModel"
        Width="320" Height="560" MinWidth="280" MinHeight="380"
        Title="MIDI Generator"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        SystemDecorations="None"
        ExtendClientAreaToDecorationsHint="True">
    <Panel>
    <Border Name="RootBorder" Background="{StaticResource CatppuccinBase}" BorderBrush="{StaticResource CatppuccinBase}"
            BorderThickness="1" CornerRadius="8" ClipToBounds="True">
        <Grid RowDefinitions="Auto,*,Auto,Auto">
            <!-- Custom title bar -->
            <Grid Grid.Row="0" Name="TitleBar" Classes="TitleBar" ColumnDefinitions="Auto, *, Auto"
                  PointerPressed="TitleBar_PointerPressed">
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- macOS "traffic light" close button (left); hidden off-Mac (toggled in ChromedWindow). -->
                    <StackPanel Name="MacWindowButtons" Orientation="Horizontal" Spacing="8"
                                VerticalAlignment="Center" Margin="14,0,8,0" IsVisible="False">
                        <Button Classes="MacButton" Background="{StaticResource CatppuccinRed}"
                                Click="CloseButton_Click" ToolTip.Tip="Close">
                            <Path Data="M0,0 L7,7 M7,0 L0,7" Stroke="#80000000" StrokeThickness="1.2" Opacity="0"
                                  VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                    <TextBlock Text="MIDI Generator" FontSize="12" Margin="10,0"
                               VerticalAlignment="Center" FontWeight="SemiBold"
                               Foreground="{StaticResource CatppuccinOverlay2}"/>
                </StackPanel>
                <StackPanel Name="StandardWindowButtons" Grid.Column="2" Orientation="Horizontal">
                    <Button Name="CloseButton" Classes="TitleBarButton Close" Click="CloseButton_Click">
                        <Path VerticalAlignment="Center" HorizontalAlignment="Center" Data="M0,0 L10,10 M10,0 L0,10"
                              Stroke="{Binding $parent[Button].Foreground}" StrokeThickness="1"/>
                    </Button>
                </StackPanel>
            </Grid>

            <ScrollViewer Grid.Row="1" Padding="14,10">
                <StackPanel Spacing="10">
                    <StackPanel.Styles>
                        <Style Selector="TextBlock.fieldLabel">
                            <Setter Property="FontSize" Value="11"/>
                            <Setter Property="Foreground" Value="{StaticResource CatppuccinSubtext0}"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Width" Value="96"/>
                        </Style>
                    </StackPanel.Styles>

                    <Grid ColumnDefinitions="Auto,*">
                        <TextBlock Classes="fieldLabel" Text="Key"/>
                        <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                  ItemsSource="{Binding RootNotes}" SelectedIndex="{Binding RootIndex}"/>
                    </Grid>
                    <Grid ColumnDefinitions="Auto,*">
                        <TextBlock Classes="fieldLabel" Text="Scale"/>
                        <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                  ItemsSource="{Binding Scales}" SelectedItem="{Binding SelectedScale}"/>
                    </Grid>
                    <Grid ColumnDefinitions="Auto,*">
                        <TextBlock Classes="fieldLabel" Text="Octave"/>
                        <NumericUpDown Grid.Column="1" Value="{Binding Octave}" Minimum="1" Maximum="7" Increment="1"/>
                    </Grid>
                    <Grid ColumnDefinitions="Auto,*">
                        <TextBlock Classes="fieldLabel" Text="Chords"/>
                        <NumericUpDown Grid.Column="1" Value="{Binding ChordCount}" Minimum="1" Maximum="32" Increment="1"/>
                    </Grid>
                    <Grid ColumnDefinitions="Auto,*">
                        <TextBlock Classes="fieldLabel" Text="Beats / chord"/>
                        <NumericUpDown Grid.Column="1" Value="{Binding ChordLengthBeats}" Minimum="0.25" Maximum="16" Increment="0.25"/>
                    </Grid>

                    <CheckBox Content="Triads" IsChecked="{Binding AllowTriads}"/>
                    <CheckBox Content="Seventh chords" IsChecked="{Binding AllowSevenths}"/>
                    <CheckBox Content="Random inversions" IsChecked="{Binding RandomInversions}"/>

                    <Border Height="1" Margin="0,4" Background="{StaticResource CatppuccinSurface0}"/>
                    <CheckBox Content="Add melody" IsChecked="{Binding AddMelody}"/>
                    <Grid ColumnDefinitions="Auto,*" IsEnabled="{Binding AddMelody}">
                        <TextBlock Classes="fieldLabel" Text="Melody rate"/>
                        <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                  ItemsSource="{Binding MelodyRates}" SelectedItem="{Binding MelodyRate}"/>
                    </Grid>
                    <Grid ColumnDefinitions="Auto,*" IsEnabled="{Binding AddMelody}">
                        <TextBlock Classes="fieldLabel" Text="Melody octave"/>
                        <NumericUpDown Grid.Column="1" Value="{Binding MelodyOctave}" Minimum="1" Maximum="4" Increment="1"/>
                    </Grid>
                    <Grid ColumnDefinitions="Auto,*" IsEnabled="{Binding AddMelody}">
                        <TextBlock Classes="fieldLabel" Text="Density %"/>
                        <NumericUpDown Grid.Column="1" Value="{Binding MelodyDensityPercent}" Minimum="10" Maximum="100" Increment="5"/>
                    </Grid>

                    <TextBlock Text="{Binding Status}" FontSize="11" TextWrapping="Wrap"
                               Foreground="{StaticResource CatppuccinSubtext1}" Margin="0,4,0,0"/>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="14,6,14,12"
                        HorizontalAlignment="Right">
                <Button Content="Generate" Click="Generate_Click"/>
                <Button Content="Insert" Click="Insert_Click"/>
                <Button Content="Replace" Click="Replace_Click"/>
            </StackPanel>
        </Grid>
    </Border>

    <!-- Resize handles -->
    <Grid IsHitTestVisible="True">
        <Border Width="4" HorizontalAlignment="Left" Cursor="LeftSide" PointerPressed="OnResizeHandlePressed" Tag="Left" Background="Transparent"/>
        <Border Width="4" HorizontalAlignment="Right" Cursor="RightSide" PointerPressed="OnResizeHandlePressed" Tag="Right" Background="Transparent"/>
        <Border Height="4" VerticalAlignment="Top" Cursor="TopSide" PointerPressed="OnResizeHandlePressed" Tag="Top" Background="Transparent"/>
        <Border Height="4" VerticalAlignment="Bottom" Cursor="BottomSide" PointerPressed="OnResizeHandlePressed" Tag="Bottom" Background="Transparent"/>
        <Border Width="8" Height="8" HorizontalAlignment="Left" VerticalAlignment="Top" Cursor="TopLeftCorner" PointerPressed="OnResizeHandlePressed" Tag="TopLeft" Background="Transparent"/>
        <Border Width="8" Height="8" HorizontalAlignment="Right" VerticalAlignment="Top" Cursor="TopRightCorner" PointerPressed="OnResizeHandlePressed" Tag="TopRight" Background="Transparent"/>
        <Border Width="8" Height="8" HorizontalAlignment="Left" VerticalAlignment="Bottom" Cursor="BottomLeftCorner" PointerPressed="OnResizeHandlePressed" Tag="BottomLeft" Background="Transparent"/>
        <Border Width="8" Height="8" HorizontalAlignment="Right" VerticalAlignment="Bottom" Cursor="BottomRightCorner" PointerPressed="OnResizeHandlePressed" Tag="BottomRight" Background="Transparent"/>
    </Grid>
    </Panel>
</Window>
