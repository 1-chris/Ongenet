<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Ongenet.Desktop.ViewModels"
             mc:Ignorable="d" d:DesignWidth="260" d:DesignHeight="70"
             x:Class="Ongenet.Desktop.Views.Panels.LibraryOptionsView"
             x:DataType="vm:LibraryOptionsViewModel">

    <Border Background="{StaticResource CatppuccinMantle}"
            BorderBrush="{StaticResource CatppuccinSurface1}" BorderThickness="0,1,0,0"
            Padding="8,6">
        <StackPanel Spacing="4">
            <CheckBox Content="Auto-stretch to fit project BPM" FontSize="11"
                      IsChecked="{Binding AutoStretch, Mode=TwoWay}"
                      ToolTip.Tip="When on, dragging a tempo-tagged loop onto the timeline time-stretches it to the project tempo"/>
            <CheckBox Content="Preserve pitch when stretching" FontSize="11" Margin="16,0,0,0"
                      IsEnabled="{Binding AutoStretch}"
                      IsChecked="{Binding PitchCorrection, Mode=TwoWay}"
                      ToolTip.Tip="Time-stretch without changing pitch (instead of resampling, which lets pitch track tempo)"/>
        </StackPanel>
    </Border>
</UserControl>
