<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Ongenet.Desktop.ViewModels"
             mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="240"
             x:Class="Ongenet.Desktop.Views.Panels.SampleInspectorView"
             x:DataType="vm:SampleInspectorViewModel">

    <Border Background="{StaticResource CatppuccinMantle}" Padding="12">
        <Grid>
            <TextBlock Text="Select an audio sample." IsVisible="{Binding !HasSample}"
                       Foreground="{StaticResource CatppuccinSubtext0}" VerticalAlignment="Top"/>

            <StackPanel IsVisible="{Binding HasSample}" Spacing="10">

                <!-- Header: sample name + source info -->
                <StackPanel Spacing="2">
                    <TextBlock Text="{Binding SampleName}" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource CatppuccinText}" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding SourceInfo}" FontSize="11"
                               Foreground="{StaticResource CatppuccinSubtext0}"/>
                </StackPanel>

                <!-- Tempo + stretch controls -->
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="Natural tempo" VerticalAlignment="Center"
                               Foreground="{StaticResource CatppuccinSubtext0}"/>
                    <NumericUpDown Value="{Binding NaturalBpm}" Minimum="0" Maximum="400" Increment="1"
                                   FormatString="0.##" Width="120" VerticalAlignment="Center"
                                   ToolTip.Tip="The sample's natural BPM (0 = unknown). Detected from the file/folder name or estimated."/>
                    <TextBlock Text="BPM" VerticalAlignment="Center"
                               Foreground="{StaticResource CatppuccinSubtext0}"/>
                </StackPanel>

                <CheckBox IsChecked="{Binding StretchEnabled}"
                          Content="Stretch to project tempo (lock to the beat grid)"
                          Foreground="{StaticResource CatppuccinText}"
                          ToolTip.Tip="When on, the sample is time-stretched so it spans a whole number of beats at the project tempo."/>

                <CheckBox IsChecked="{Binding PitchCorrected}" IsEnabled="{Binding StretchEnabled}" Margin="20,0,0,0"
                          Content="Preserve pitch when stretching"
                          Foreground="{StaticResource CatppuccinText}"
                          ToolTip.Tip="Time-stretch without changing pitch (instead of resampling, which lets pitch track tempo)."/>

                <!-- Read-outs -->
                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" >
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Stretch" Margin="0,0,12,2"
                               Foreground="{StaticResource CatppuccinSubtext0}"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding StretchInfo}" Margin="0,0,0,2"
                               Foreground="{StaticResource CatppuccinText}"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Grid length" Margin="0,0,12,0"
                               Foreground="{StaticResource CatppuccinSubtext0}"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding LengthInfo}"
                               Foreground="{StaticResource CatppuccinText}"/>
                </Grid>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
