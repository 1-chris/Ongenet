<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:fx="using:Ongenet.Desktop.ViewModels.Effects"
             xmlns:controls="using:Ongenet.Desktop.Controls"
             xmlns:panels="using:Ongenet.Desktop.Views.Panels"
             mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="200"
             x:Class="Ongenet.Desktop.Views.Panels.EffectChainView"
             x:DataType="fx:EffectChainViewModel">

    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="10" Margin="0,0,0,8">
            <Button Content="+ Add effect" Background="{StaticResource CatppuccinSurface0}">
                <Button.Flyout>
                    <Flyout>
                        <ScrollViewer MaxHeight="420">
                            <ItemsControl ItemsSource="{Binding AddableCategories}" Width="170">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="fx:EffectCategoryViewModel">
                                        <StackPanel Margin="0,0,0,6">
                                            <TextBlock Text="{Binding Name}" FontSize="10" FontWeight="Bold"
                                                       Margin="2,4,2,2"
                                                       Foreground="{StaticResource CatppuccinOverlay1}"/>
                                            <ItemsControl ItemsSource="{Binding Effects}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="fx:AvailableEffectViewModel">
                                                        <Button Content="{Binding Name}" Command="{Binding AddCommand}"
                                                                HorizontalAlignment="Stretch" Margin="0,1"
                                                                HorizontalContentAlignment="Left"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Flyout>
                </Button.Flyout>
            </Button>
            <Button Name="SaveChainButton" Content="Save chain…" IsVisible="{Binding HasEffects}"
                    Background="{StaticResource CatppuccinSurface0}"
                    ToolTip.Tip="Save this whole effect chain as a preset">
                <Button.Flyout>
                    <Flyout>
                        <StackPanel Width="200" Spacing="6">
                            <TextBlock Text="FX chain name" FontSize="11"
                                       Foreground="{StaticResource CatppuccinSubtext0}"/>
                            <TextBox Text="{Binding ChainPresetName, Mode=TwoWay}" Watermark="FX Chain"/>
                            <Button Content="Save" Click="OnSaveChain" HorizontalAlignment="Right"
                                    Background="{StaticResource CatppuccinSurface1}"/>
                        </StackPanel>
                    </Flyout>
                </Button.Flyout>
            </Button>
            <TextBlock Text="signal chain: top = first → bottom = last" VerticalAlignment="Center"
                       FontSize="11" FontStyle="Italic" IsVisible="{Binding HasEffects}"
                       Foreground="{StaticResource CatppuccinOverlay1}"/>
        </StackPanel>

        <ItemsControl ItemsSource="{Binding Effects}">
            <ItemsControl.DataTemplates>
                <!-- EQ: interactive parametric-EQ graph. -->
                <DataTemplate DataType="fx:EqEffectViewModel">
                    <Border Margin="0,0,0,8" Padding="10" CornerRadius="4"
                            Background="{StaticResource CatppuccinSurface0}"
                            BorderBrush="{StaticResource CatppuccinSurface1}" BorderThickness="1">
                        <StackPanel Spacing="6">
                            <panels:EffectHeaderView/>
                            <Border CornerRadius="4" ClipToBounds="True"
                                    BorderBrush="{StaticResource CatppuccinSurface1}" BorderThickness="1">
                                <controls:EqGraphControl Height="180"
                                                         Eq="{Binding Eq}"
                                                         Source="{Binding Source}"/>
                            </Border>
                            <TextBlock FontSize="10" Foreground="{StaticResource CatppuccinSubtext0}"
                                       Text="Double-click to add a band · drag to move · wheel for Q · right-click for type / delete"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>

                <!-- Filter: card with the analyser graph above the knobs. -->
                <DataTemplate DataType="fx:FilterEffectViewModel">
                    <Border Margin="0,0,0,8" Padding="10" CornerRadius="4"
                            Background="{StaticResource CatppuccinSurface0}"
                            BorderBrush="{StaticResource CatppuccinSurface1}" BorderThickness="1">
                        <StackPanel Spacing="6">
                            <panels:EffectHeaderView/>
                            <Border CornerRadius="4" ClipToBounds="True"
                                    BorderBrush="{StaticResource CatppuccinSurface1}" BorderThickness="1">
                                <controls:FilterResponseControl Height="120"
                                                                SampleRate="{Binding SampleRate}"
                                                                Source="{Binding Source}"
                                                                Frequency="{Binding FrequencyParam.Value, Mode=TwoWay}"
                                                                Resonance="{Binding ResonanceParam.Value, Mode=TwoWay}"
                                                                Mode="{Binding ModeParam.SelectedIndex}"/>
                            </Border>
                            <panels:ParametersView DataContext="{Binding Parameters}"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>

                <!-- Sidechain: a source picker (Tempo / a track) above the generic knobs. -->
                <DataTemplate DataType="fx:SidechainEffectViewModel">
                    <Border Margin="0,0,0,8" Padding="10" CornerRadius="4"
                            Background="{StaticResource CatppuccinSurface0}"
                            BorderBrush="{StaticResource CatppuccinSurface1}" BorderThickness="1">
                        <StackPanel Spacing="6">
                            <panels:EffectHeaderView/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Source" VerticalAlignment="Center" Width="50"
                                           Foreground="{StaticResource CatppuccinSubtext0}"/>
                                <ComboBox Width="200" ItemsSource="{Binding Sources}"
                                          SelectedItem="{Binding SelectedSource, Mode=TwoWay}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="fx:SourceTrackOption">
                                            <TextBlock Text="{Binding Name}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                            <panels:ParametersView DataContext="{Binding Parameters}"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>

                <!-- Vocoder: a carrier-track picker above the generic knobs. -->
                <DataTemplate DataType="fx:VocoderEffectViewModel">
                    <Border Margin="0,0,0,8" Padding="10" CornerRadius="4"
                            Background="{StaticResource CatppuccinSurface0}"
                            BorderBrush="{StaticResource CatppuccinSurface1}" BorderThickness="1">
                        <StackPanel Spacing="6">
                            <panels:EffectHeaderView/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Carrier" VerticalAlignment="Center" Width="50"
                                           Foreground="{StaticResource CatppuccinSubtext0}"/>
                                <ComboBox Width="200" ItemsSource="{Binding Sources}"
                                          SelectedItem="{Binding SelectedSource, Mode=TwoWay}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="fx:SourceTrackOption">
                                            <TextBlock Text="{Binding Name}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                            <panels:ParametersView DataContext="{Binding Parameters}"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>

                <!-- Stuttero: gestures, a shared curve editor, and the reorderable FX rack. -->
                <DataTemplate DataType="fx:StutteroEffectViewModel">
                    <Border Margin="0,0,0,8" Padding="10" CornerRadius="4"
                            Background="{StaticResource CatppuccinSurface0}"
                            BorderBrush="{StaticResource CatppuccinSurface1}" BorderThickness="1">
                        <StackPanel Spacing="8">
                            <panels:EffectHeaderView/>
                            <panels:ParametersView DataContext="{Binding Parameters}"/>

                            <!-- Auto-mode gesture + gesture list -->
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Auto gesture" VerticalAlignment="Center" Width="80"
                                           Foreground="{StaticResource CatppuccinSubtext0}"/>
                                <ComboBox Width="180" ItemsSource="{Binding AutoGestureOptions}"
                                          SelectedIndex="{Binding AutoGestureIndex, Mode=TwoWay}"/>
                            </StackPanel>

                            <Grid ColumnDefinitions="200,*" Height="190">
                                <DockPanel Grid.Column="0" Margin="0,0,8,0">
                                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
                                        <Button Content="+ Gesture" Command="{Binding AddGestureCommand}"
                                                Background="{StaticResource CatppuccinSurface1}"/>
                                        <Button Content="–" Command="{Binding RemoveGestureCommand}"
                                                Background="{StaticResource CatppuccinSurface1}"/>
                                    </StackPanel>
                                    <ListBox ItemsSource="{Binding Gestures}"
                                             SelectedItem="{Binding SelectedGesture, Mode=TwoWay}"
                                             Background="{StaticResource CatppuccinMantle}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate x:DataType="fx:GestureItemViewModel">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <TextBlock Text="{Binding Name}"/>
                                                    <TextBlock Text="{Binding TriggerKeyName}" FontSize="10"
                                                               Foreground="{StaticResource CatppuccinOverlay1}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </DockPanel>

                                <!-- Selected gesture detail -->
                                <ScrollViewer Grid.Column="1">
                                    <StackPanel Spacing="6" IsVisible="{Binding HasSelectedGesture}"
                                                DataContext="{Binding SelectedGesture}">
                                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto"
                                              x:DataType="fx:GestureItemViewModel">
                                            <TextBlock Text="Name" Grid.Row="0" Grid.Column="0" Width="70"
                                                       VerticalAlignment="Center" Foreground="{StaticResource CatppuccinSubtext0}"/>
                                            <TextBox Text="{Binding Name, Mode=TwoWay}" Grid.Row="0" Grid.Column="1" Margin="0,0,0,2"/>
                                        </Grid>
                                        <StackPanel Orientation="Horizontal" Spacing="8" x:DataType="fx:GestureItemViewModel">
                                            <StackPanel>
                                                <TextBlock Text="Rate" FontSize="10" Foreground="{StaticResource CatppuccinSubtext0}"/>
                                                <ComboBox Width="80" ItemsSource="{Binding RateOptions}"
                                                          SelectedIndex="{Binding RateIndex, Mode=TwoWay}"/>
                                            </StackPanel>
                                            <StackPanel>
                                                <TextBlock Text="Buffer" FontSize="10" Foreground="{StaticResource CatppuccinSubtext0}"/>
                                                <ComboBox Width="90" ItemsSource="{Binding BufferOptions}"
                                                          SelectedIndex="{Binding BufferModeIndex, Mode=TwoWay}"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel x:DataType="fx:GestureItemViewModel">
                                            <TextBlock FontSize="10" Foreground="{StaticResource CatppuccinSubtext0}"
                                                       Text="{Binding TriggerKeyName, StringFormat='Trigger key: {0}'}"/>
                                            <Slider Minimum="-1" Maximum="127" TickFrequency="1" IsSnapToTickEnabled="True"
                                                    Value="{Binding TriggerKey, Mode=TwoWay}"/>
                                            <Grid ColumnDefinitions="*,*">
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Buffer length (beats)" FontSize="10"
                                                               Foreground="{StaticResource CatppuccinSubtext0}"/>
                                                    <Slider Minimum="0.0625" Maximum="4" Value="{Binding BufferLengthBeats, Mode=TwoWay}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="Tail (ms)" FontSize="10"
                                                               Foreground="{StaticResource CatppuccinSubtext0}"/>
                                                    <Slider Minimum="0" Maximum="120" Value="{Binding TailMs, Mode=TwoWay}"/>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>

                            <!-- Curve editor + target/preset toolbar -->
                            <StackPanel Spacing="4" IsVisible="{Binding HasSelectedGesture}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <ComboBox Width="150" ItemsSource="{Binding CurveTargets}"
                                              SelectedItem="{Binding SelectedTarget, Mode=TwoWay}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate x:DataType="fx:CurveTargetViewModel">
                                                <TextBlock Text="{Binding Label}"/>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <ComboBox Width="110" ItemsSource="{Binding CurvePresets}"
                                              SelectedIndex="{Binding SelectedPreset, Mode=TwoWay}"/>
                                    <Button Content="Apply" Command="{Binding ApplyPresetCommand}"
                                            Background="{StaticResource CatppuccinSurface1}"/>
                                    <CheckBox Content="Palindrome" IsChecked="{Binding Palindrome, Mode=TwoWay}"/>
                                    <Button Content="Clear" Command="{Binding ClearCurveCommand}"
                                            IsEnabled="{Binding CanClearCurve}"
                                            Background="{StaticResource CatppuccinSurface1}"/>
                                </StackPanel>
                                <Border CornerRadius="4" ClipToBounds="True" Height="150"
                                        BorderBrush="{StaticResource CatppuccinSurface1}" BorderThickness="1"
                                        Background="{StaticResource CatppuccinMantle}">
                                    <controls:CurveEditorControl Curve="{Binding EditCurve}"
                                                                 Revision="{Binding CurveRevision}"
                                                                 SnapDivisions="16"/>
                                </Border>
                                <TextBlock FontSize="10" Foreground="{StaticResource CatppuccinSubtext0}"
                                           Text="Double-click to add a node · drag to move · drag a segment to bend · right-click to delete"/>
                            </StackPanel>

                            <!-- Reorderable FX rack -->
                            <TextBlock Text="FX rack (top = first)" FontWeight="Bold" FontSize="11"
                                       Foreground="{StaticResource CatppuccinOverlay1}"/>
                            <ItemsControl ItemsSource="{Binding Modules}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="fx:ModuleItemViewModel">
                                        <Border Margin="0,0,0,4" Padding="6" CornerRadius="3"
                                                Background="{StaticResource CatppuccinMantle}"
                                                BorderBrush="{StaticResource CatppuccinSurface1}" BorderThickness="1">
                                            <StackPanel Spacing="4">
                                                <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsEnabled, Mode=TwoWay}"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center"/>
                                                    <Button Grid.Column="2" Content="▲" Command="{Binding MoveUpCommand}"
                                                            IsEnabled="{Binding !IsFirst}" Padding="6,0" Margin="2,0"
                                                            Background="{StaticResource CatppuccinSurface1}"/>
                                                    <Button Grid.Column="3" Content="▼" Command="{Binding MoveDownCommand}"
                                                            IsEnabled="{Binding !IsLast}" Padding="6,0"
                                                            Background="{StaticResource CatppuccinSurface1}"/>
                                                </Grid>
                                                <Expander Header="parameters" IsVisible="{Binding IsEnabled}">
                                                    <panels:ParametersView DataContext="{Binding Parameters}"/>
                                                </Expander>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </DataTemplate>

                <!-- Default effect card (built-in effects + CLAP audio-effect plugins). -->
                <DataTemplate DataType="fx:EffectViewModel">
                    <Border Margin="0,0,0,8" Padding="10" CornerRadius="4"
                            Background="{StaticResource CatppuccinSurface0}"
                            BorderBrush="{StaticResource CatppuccinSurface1}" BorderThickness="1">
                        <StackPanel Spacing="6">
                            <panels:EffectHeaderView/>
                            <panels:ParametersView DataContext="{Binding Parameters}"/>
                            <Button Content="{Binding EditorButtonText}" IsVisible="{Binding HasEditor}"
                                    Click="OnToggleEffectPluginUi" HorizontalAlignment="Left"
                                    Background="{StaticResource CatppuccinSurface1}"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.DataTemplates>
        </ItemsControl>
    </DockPanel>
</UserControl>
