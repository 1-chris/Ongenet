<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:inst="using:Ongenet.Desktop.ViewModels.Instruments"
             xmlns:panels="using:Ongenet.Desktop.Views.Panels"
             xmlns:controls="using:Ongenet.Desktop.Controls"
             mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="260"
             x:Class="Ongenet.Desktop.Views.Panels.InstrumentSlotView"
             x:DataType="inst:InstrumentSlotViewModel">

    <UserControl.Styles>
        <Style Selector="Button.fxdot">
            <Setter Property="Width" Value="16"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Styles>

    <Border Margin="0,0,0,8" Padding="10" CornerRadius="4"
            Background="{StaticResource CatppuccinSurface0}"
            BorderBrush="{StaticResource CatppuccinSurface1}" BorderThickness="1">
        <StackPanel Spacing="6">

            <!-- Header: enable dot, name, specialised loaders/plugin UI, reorder + remove -->
            <DockPanel>
                <Button DockPanel.Dock="Left" Classes="fxdot" Margin="0,0,8,0"
                        Command="{Binding ToggleEnabledCommand}"
                        ToolTip.Tip="Enable / disable instrument">
                    <Panel>
                        <Ellipse Width="12" Height="12" IsVisible="{Binding IsEnabled}"
                                 Fill="{StaticResource CatppuccinGreen}"/>
                        <Ellipse Width="12" Height="12" IsVisible="{Binding !IsEnabled}"
                                 Fill="{StaticResource CatppuccinRed}"/>
                    </Panel>
                </Button>

                <Button DockPanel.Dock="Right" Content="✕" Command="{Binding RemoveCommand}"
                        Background="{StaticResource CatppuccinSurface1}" Padding="6,0"
                        ToolTip.Tip="Remove instrument"/>
                <Button DockPanel.Dock="Right" Content="▼" Command="{Binding MoveDownCommand}"
                        IsEnabled="{Binding !IsLast}" Background="{StaticResource CatppuccinSurface1}"
                        Padding="6,0" Margin="2,0"/>
                <Button DockPanel.Dock="Right" Content="▲" Command="{Binding MoveUpCommand}"
                        IsEnabled="{Binding !IsFirst}" Background="{StaticResource CatppuccinSurface1}"
                        Padding="6,0" Margin="2,0"/>

                <WrapPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding InstrumentName}" FontWeight="Bold" FontSize="12"
                               VerticalAlignment="Center" Margin="0,0,16,0"
                               Foreground="{StaticResource CatppuccinMauve}"/>

                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,16,0"
                                VerticalAlignment="Center" IsVisible="{Binding IsPresetProvider}">
                        <TextBlock Text="Preset" VerticalAlignment="Center" FontSize="11"
                                   Foreground="{StaticResource CatppuccinSubtext0}"/>
                        <ComboBox MinWidth="150" ItemsSource="{Binding PresetNames}"
                                  SelectedIndex="{Binding SelectedPreset}"
                                  PlaceholderText="Choose a preset…"
                                  Background="{StaticResource CatppuccinSurface1}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,16,0"
                                VerticalAlignment="Center" IsVisible="{Binding IsSampler}">
                        <Button Content="Load sample…" Click="OnLoadSample"
                                Background="{StaticResource CatppuccinSurface1}"/>
                        <TextBlock Text="{Binding SampleName}" VerticalAlignment="Center"
                                   MaxWidth="220" FontSize="11" TextTrimming="CharacterEllipsis"
                                   Foreground="{StaticResource CatppuccinSubtext0}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,16,0"
                                VerticalAlignment="Center" IsVisible="{Binding IsSfz}">
                        <Button Content="Load SFZ…" Click="OnLoadSfz"
                                Background="{StaticResource CatppuccinSurface1}"/>
                        <TextBlock Text="{Binding SfzStatus}" VerticalAlignment="Center"
                                   MaxWidth="260" FontSize="11" TextTrimming="CharacterEllipsis"
                                   Foreground="{StaticResource CatppuccinSubtext0}"/>
                        <ProgressBar Width="120" Height="6" Minimum="0" Maximum="1"
                                     Value="{Binding SfzLoadProgress}" IsVisible="{Binding IsSfzLoading}"
                                     VerticalAlignment="Center"
                                     Foreground="{StaticResource CatppuccinMauve}"/>
                    </StackPanel>

                    <Button Content="{Binding EditorButtonText}" Click="OnTogglePluginUi"
                            IsVisible="{Binding HasEditor}" VerticalAlignment="Center"
                            Background="{StaticResource CatppuccinSurface1}"
                            ToolTip.Tip="Open the plugin's own interface"/>
                </WrapPanel>
            </DockPanel>

            <!-- Parameters -->
            <panels:GroupedParametersView DataContext="{Binding ParameterGroups}"/>

            <!-- Grain monitor (granular synth only) -->
            <Border Height="96" CornerRadius="4" ClipToBounds="True" IsVisible="{Binding IsGranular}"
                    BorderBrush="{StaticResource CatppuccinSurface1}" BorderThickness="1">
                <Grid>
                    <controls:GrainMonitorControl Monitor="{Binding GrainMonitor}"/>
                    <TextBlock Text="GRAINS" FontSize="9" Margin="6,4"
                               VerticalAlignment="Top" HorizontalAlignment="Left"
                               IsHitTestVisible="False"
                               Foreground="{StaticResource CatppuccinOverlay1}"/>
                </Grid>
            </Border>

            <!-- Waveform preview (instruments that render a one-shot, e.g. Kicka) -->
            <Border Height="96" CornerRadius="4" ClipToBounds="True" IsVisible="{Binding IsPreviewable}"
                    Background="{StaticResource CatppuccinCrust}"
                    BorderBrush="{StaticResource CatppuccinSurface1}" BorderThickness="1">
                <Grid>
                    <controls:WaveformControl Waveform="{Binding InstrumentPreview}"
                                              Revision="{Binding PreviewRevision}"
                                              Fill="{StaticResource CatppuccinMauve}"/>
                    <TextBlock Text="WAVEFORM" FontSize="9" Margin="6,4"
                               VerticalAlignment="Top" HorizontalAlignment="Left"
                               IsHitTestVisible="False"
                               Foreground="{StaticResource CatppuccinOverlay1}"/>
                </Grid>
            </Border>

            <!-- SFZ "Sampler": zone map + amp envelope + live controllers -->
            <Border Height="150" CornerRadius="4" ClipToBounds="True" IsVisible="{Binding IsSfz}"
                    Background="{StaticResource CatppuccinCrust}"
                    BorderBrush="{StaticResource CatppuccinSurface1}" BorderThickness="1">
                <Grid ColumnDefinitions="*,220">
                    <Grid Grid.Column="0">
                        <controls:ZoneMapControl Zones="{Binding SfzZones}" Revision="{Binding SfzRevision}"/>
                        <TextBlock Text="ZONES  (key × velocity)" FontSize="9" Margin="6,4"
                                   VerticalAlignment="Top" HorizontalAlignment="Left"
                                   IsHitTestVisible="False"
                                   Foreground="{StaticResource CatppuccinOverlay1}"/>
                    </Grid>

                    <DockPanel Grid.Column="1" Margin="8,4,6,6" LastChildFill="True">
                        <TextBlock DockPanel.Dock="Top" Text="AMP ENVELOPE" FontSize="9"
                                   Foreground="{StaticResource CatppuccinOverlay1}"/>
                        <Grid DockPanel.Dock="Bottom" ColumnDefinitions="*,*" Margin="0,6,0,0">
                            <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                <TextBlock Text="Mod" FontSize="10"
                                           Foreground="{StaticResource CatppuccinSubtext0}"/>
                                <Slider Minimum="0" Maximum="127" Value="{Binding ModWheel, Mode=TwoWay}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                <TextBlock Text="Bend" FontSize="10"
                                           Foreground="{StaticResource CatppuccinSubtext0}"/>
                                <Slider Minimum="0" Maximum="16383" Value="{Binding PitchBendValue, Mode=TwoWay}"
                                        PointerReleased="OnBendReleased" PointerCaptureLost="OnBendCaptureLost"/>
                            </StackPanel>
                        </Grid>
                        <controls:EnvelopeDisplayControl MinHeight="40"
                            Delay="{Binding EnvDelay}" Attack="{Binding EnvAttack}"
                            Hold="{Binding EnvHold}" Decay="{Binding EnvDecay}"
                            Sustain="{Binding EnvSustain}" Release="{Binding EnvRelease}"/>
                    </DockPanel>
                </Grid>
            </Border>

            <!-- This instrument's own (pre) effect chain -->
            <Expander Header="Instrument FX (pre)" Margin="0,2,0,0">
                <panels:EffectChainView DataContext="{Binding Effects}" Margin="0,6,0,0"/>
            </Expander>
        </StackPanel>
    </Border>
</UserControl>
