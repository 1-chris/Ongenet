<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Ongenet.Desktop.ViewModels"
             mc:Ignorable="d" d:DesignWidth="240" d:DesignHeight="600"
             x:Class="Ongenet.Desktop.Views.Panels.TrackInspectorView"
             x:DataType="vm:TrackInspectorViewModel">

    <UserControl.Resources>
        <!-- Fluent reserves 15px above/below the slider thumb for tick bars we don't use,
             which both wastes space and clips the thumb when the control is made compact.
             Zero the reservations so sliders collapse to the thumb's natural 20px height. -->
        <GridLength x:Key="SliderPreContentMargin">0</GridLength>
        <GridLength x:Key="SliderPostContentMargin">0</GridLength>
        <x:Double x:Key="SliderHorizontalHeight">20</x:Double>
    </UserControl.Resources>

    <Border Background="{StaticResource CatppuccinMantle}" Padding="10,8">
        <Grid>
            <!-- Empty state -->
            <TextBlock Text="Select a track to edit its settings."
                       IsVisible="{Binding !HasTrack}"
                       TextWrapping="Wrap" VerticalAlignment="Top"
                       Foreground="{StaticResource CatppuccinSubtext0}"/>

            <!-- Track settings -->
            <ScrollViewer IsVisible="{Binding HasTrack}"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="4">
                    <TextBlock Text="TRACK" FontWeight="Bold" FontSize="11"
                               Foreground="{StaticResource CatppuccinOverlay1}"/>

                    <StackPanel Spacing="1">
                        <TextBlock Text="Name" Foreground="{StaticResource CatppuccinSubtext0}"/>
                        <TextBox Text="{Binding Name}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <ToggleButton Content="Mute" IsChecked="{Binding IsMuted}" Width="80"/>
                        <ToggleButton Content="Solo" IsChecked="{Binding IsSoloed}" Width="80"/>
                    </StackPanel>

                    <StackPanel Spacing="1">
                        <DockPanel>
                            <TextBlock Text="Volume" Foreground="{StaticResource CatppuccinSubtext0}"/>
                            <TextBlock Text="{Binding Volume, StringFormat='{}{0:P0}'}"
                                       HorizontalAlignment="Right"
                                       Foreground="{StaticResource CatppuccinSubtext1}"/>
                        </DockPanel>
                        <Slider Name="VolumeSlider" Value="{Binding Volume}" Minimum="0" Maximum="1"/>
                    </StackPanel>

                    <StackPanel Spacing="1">
                        <DockPanel>
                            <TextBlock Text="Pan" Foreground="{StaticResource CatppuccinSubtext0}"/>
                            <TextBlock Text="{Binding Pan, StringFormat='{}{0:0.00}'}"
                                       HorizontalAlignment="Right"
                                       Foreground="{StaticResource CatppuccinSubtext1}"/>
                        </DockPanel>
                        <Slider Name="PanSlider" Value="{Binding Pan}" Minimum="-1" Maximum="1"/>
                    </StackPanel>

                    <StackPanel Spacing="1">
                        <TextBlock Text="Colour" Foreground="{StaticResource CatppuccinSubtext0}"/>
                        <ComboBox ItemsSource="{Binding ColorKeys}"
                                  SelectedItem="{Binding ColorKey}"
                                  HorizontalAlignment="Stretch">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Border Width="14" Height="14" CornerRadius="3"
                                                Background="{Binding Converter={StaticResource ColorKeyToBrush}}"/>
                                        <TextBlock Text="{Binding}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
