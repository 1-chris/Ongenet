<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Ongenet.App.ViewModels"
             xmlns:audio="using:Ongenet.Core.Audio"
             mc:Ignorable="d" d:DesignWidth="460" d:DesignHeight="320"
             x:Class="Ongenet.App.Views.Settings.AudioSettingsView"
             x:DataType="vm:AudioDevicesViewModel">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="18" Spacing="14">
            <TextBlock Text="Audio system" FontSize="14" FontWeight="SemiBold"
                       Foreground="{StaticResource CatppuccinText}"/>

            <Grid ColumnDefinitions="100,*" ColumnSpacing="10">
                <TextBlock Grid.Column="0" Text="Backend" VerticalAlignment="Center"
                           Foreground="{StaticResource CatppuccinSubtext1}"/>
                <ComboBox Grid.Column="1" HorizontalAlignment="Left" Width="220"
                          ItemsSource="{Binding Backends}" SelectedItem="{Binding SelectedBackend}"
                          ToolTip.Tip="Low-level audio API. PortAudio is the default; Native talks to the OS audio stack directly.">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="audio:AudioBackendInfo">
                            <TextBlock Text="{Binding DisplayName}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </Grid>

            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource CatppuccinOverlay1}"
                       Text="Switching backend reopens the audio stream immediately. Native (Linux) is experimental — PortAudio is the recommended default."/>

            <Border Height="1" Background="{StaticResource CatppuccinSurface0}" Margin="0,2"/>

            <TextBlock Text="Audio devices" FontSize="14" FontWeight="SemiBold"
                       Foreground="{StaticResource CatppuccinText}"/>

            <Grid ColumnDefinitions="100,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="10" ColumnSpacing="10">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Output" VerticalAlignment="Center"
                           Foreground="{StaticResource CatppuccinSubtext1}"/>
                <ComboBox Grid.Row="0" Grid.Column="1" HorizontalAlignment="Stretch"
                          ItemsSource="{Binding OutputDevices}" SelectedItem="{Binding SelectedOutput}"
                          ToolTip.Tip="Audio output device">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="audio:AudioDevice">
                            <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Input" VerticalAlignment="Center"
                           Foreground="{StaticResource CatppuccinSubtext1}"/>
                <ComboBox Grid.Row="1" Grid.Column="1" HorizontalAlignment="Stretch"
                          ItemsSource="{Binding InputDevices}" SelectedItem="{Binding SelectedInput}"
                          ToolTip.Tip="Audio input device (for recording)">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="audio:AudioDevice">
                            <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Input mode" VerticalAlignment="Center"
                           Foreground="{StaticResource CatppuccinSubtext1}"/>
                <ComboBox Grid.Row="2" Grid.Column="1" HorizontalAlignment="Left" Width="140"
                          ItemsSource="{Binding InputChannelModes}" SelectedItem="{Binding InputChannelMode}"
                          ToolTip.Tip="Record the input as Stereo (as-is) or Mono (centered)"/>
            </Grid>

            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource CatppuccinOverlay1}"
                       Text="Changing the output device reopens the audio stream immediately. The input device applies the next time recording starts."/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
