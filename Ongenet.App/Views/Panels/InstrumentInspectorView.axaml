<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Ongenet.App.ViewModels"
             xmlns:inst="using:Ongenet.App.ViewModels.Instruments"
             xmlns:instc="using:Ongenet.Core.Audio.Instruments"
             xmlns:panels="using:Ongenet.App.Views.Panels"
             mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="280"
             DragDrop.AllowDrop="True"
             x:Class="Ongenet.App.Views.Panels.InstrumentInspectorView"
             x:DataType="vm:InstrumentInspectorViewModel">

    <UserControl.Styles>
        <Style Selector="Border.key">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Margin" Value="1,0"/>
            <Setter Property="CornerRadius" Value="0,0,4,4"/>
            <Setter Property="Background" Value="{StaticResource CatppuccinSubtext1}"/>
        </Style>
        <Style Selector="Border.key.black">
            <Setter Property="Background" Value="{StaticResource CatppuccinSurface1}"/>
        </Style>
        <Style Selector="Border.key:pointerover">
            <Setter Property="Background" Value="{StaticResource CatppuccinMauve}"/>
        </Style>
        <Style Selector="Border.key.active">
            <Setter Property="Background" Value="{StaticResource CatppuccinMauve}"/>
        </Style>
    </UserControl.Styles>

    <Border Background="{StaticResource CatppuccinMantle}" Padding="12" Name="Root">
        <Grid>
            <TextBlock Text="Select an instrument track." IsVisible="{Binding !HasInstrumentTrack}"
                       Foreground="{StaticResource CatppuccinSubtext0}" VerticalAlignment="Top"/>

            <!-- Rows: header (add menu) / rack (fills + scrolls) / keyboard -->
            <Grid IsVisible="{Binding HasInstrumentTrack}" RowDefinitions="Auto,*,Auto">

                <!-- Header: add-instrument menu + caption -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" Margin="0,0,0,8">
                    <Button Content="+ Add instrument" Background="{StaticResource CatppuccinSurface0}">
                        <Button.Flyout>
                            <Flyout>
                                <ScrollViewer MaxHeight="420">
                                    <ItemsControl ItemsSource="{Binding AddableCategories}" Width="180">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:InstrumentCategoryViewModel">
                                                <StackPanel Margin="0,0,0,6">
                                                    <TextBlock Text="{Binding Name}" FontSize="10" FontWeight="Bold"
                                                               Margin="2,4,2,2"
                                                               Foreground="{StaticResource CatppuccinOverlay1}"/>
                                                    <ItemsControl ItemsSource="{Binding Instruments}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="instc:InstrumentInfo">
                                                                <Button Content="{Binding DisplayName}" Click="OnAddInstrument"
                                                                        HorizontalAlignment="Stretch" Margin="0,1"
                                                                        HorizontalContentAlignment="Left"/>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                    <TextBlock Text="{Binding TrackName}" VerticalAlignment="Center"
                               Foreground="{StaticResource CatppuccinSubtext0}"/>
                    <TextBlock Text="all instruments play together · drag from the Instruments panel to add"
                               VerticalAlignment="Center" FontSize="11" FontStyle="Italic"
                               Foreground="{StaticResource CatppuccinOverlay1}"/>
                </StackPanel>

                <!-- Rack of instrument cards, or an empty-state drop zone -->
                <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
                    <Grid>
                        <Border IsVisible="{Binding IsEmpty}" Height="120" CornerRadius="6"
                                BorderBrush="{StaticResource CatppuccinSurface1}" BorderThickness="2"
                                Background="{StaticResource CatppuccinCrust}">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="4">
                                <TextBlock Text="No instruments yet" FontWeight="Bold" HorizontalAlignment="Center"
                                           Foreground="{StaticResource CatppuccinSubtext0}"/>
                                <TextBlock Text="Drag an instrument here from the Instruments panel, or use “+ Add instrument”."
                                           FontSize="11" HorizontalAlignment="Center" TextWrapping="Wrap"
                                           Foreground="{StaticResource CatppuccinOverlay1}"/>
                            </StackPanel>
                        </Border>

                        <ItemsControl ItemsSource="{Binding Slots}" IsVisible="{Binding !IsEmpty}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="inst:InstrumentSlotViewModel">
                                    <panels:InstrumentSlotView/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </ScrollViewer>

                <!-- Shared mini keyboard: plays every enabled instrument at once -->
                <StackPanel Grid.Row="2" Spacing="4" Margin="0,8,0,0">
                    <TextBlock Text="Click keys to play" FontSize="11"
                               Foreground="{StaticResource CatppuccinSubtext0}"/>
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Keys}" Name="Keyboard">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="inst:KeyViewModel">
                                    <Border Classes="key" Classes.black="{Binding IsBlack}"
                                            Classes.active="{Binding IsActive}" Height="72"
                                            PointerPressed="OnKeyPressed"
                                            PointerReleased="OnKeyReleased"
                                            PointerExited="OnKeyExited">
                                        <TextBlock Text="{Binding Label}" FontSize="9"
                                                   HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                                   Margin="0,0,0,4"
                                                   Foreground="{StaticResource CatppuccinCrust}"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>
