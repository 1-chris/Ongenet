<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fx="using:Ongenet.App.ViewModels.Effects"
             x:Class="Ongenet.App.Views.Panels.EffectHeaderView"
             x:DataType="fx:EffectViewModel">

    <UserControl.Styles>
        <Style Selector="Button.fxdot">
            <Setter Property="Width" Value="16"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.ord">
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="{StaticResource CatppuccinSurface1}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Styles>

    <DockPanel>
        <!-- Enable / bypass dot -->
        <Button DockPanel.Dock="Left" Classes="fxdot" Margin="0,0,8,0" Name="BypassDot"
                Command="{Binding ToggleEnabledCommand}"
                ToolTip.Tip="Enable / bypass effect (right-click to automate)">
            <Panel>
                <Ellipse Width="12" Height="12" IsVisible="{Binding IsEnabled}"
                         Fill="{StaticResource CatppuccinGreen}"/>
                <Ellipse Width="12" Height="12" IsVisible="{Binding !IsEnabled}"
                         Fill="{StaticResource CatppuccinRed}"/>
            </Panel>
        </Button>

        <!-- Chain position badge -->
        <Border DockPanel.Dock="Left" Margin="0,0,8,0" Width="20" Height="20" CornerRadius="10"
                Background="{StaticResource CatppuccinSurface2}" VerticalAlignment="Center"
                ToolTip.Tip="Processing order (1 = first)">
            <TextBlock Text="{Binding Position}" FontSize="11" FontWeight="SemiBold"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="{StaticResource CatppuccinText}"/>
        </Border>

        <!-- Right-aligned controls: save-preset / move up / down / remove -->
        <Button DockPanel.Dock="Right" Content="✕" Padding="6,2" Background="Transparent"
                Foreground="{StaticResource CatppuccinRed}"
                Command="{Binding RemoveCommand}" ToolTip.Tip="Remove effect" VerticalAlignment="Center"/>
        <Button DockPanel.Dock="Right" Name="SaveEffectPresetButton" Content="💾" Classes="ord" Margin="0,0,4,0"
                ToolTip.Tip="Save this effect's settings as a preset">
            <Button.Flyout>
                <Flyout>
                    <StackPanel Width="200" Spacing="6">
                        <TextBlock Text="Preset name" FontSize="11"
                                   Foreground="{StaticResource CatppuccinSubtext0}"/>
                        <TextBox Text="{Binding PresetName, Mode=TwoWay}" Watermark="{Binding Name}"/>
                        <Button Content="Save" Click="OnSaveEffectPreset" HorizontalAlignment="Right"
                                Background="{StaticResource CatppuccinSurface1}"/>
                    </StackPanel>
                </Flyout>
            </Button.Flyout>
        </Button>
        <Button DockPanel.Dock="Right" Classes="ord" Content="▼" Margin="0,0,4,0"
                Command="{Binding MoveDownCommand}" IsEnabled="{Binding !IsLast}"
                ToolTip.Tip="Move later in the chain"/>
        <Button DockPanel.Dock="Right" Classes="ord" Content="▲" Margin="0,0,4,0"
                Command="{Binding MoveUpCommand}" IsEnabled="{Binding !IsFirst}"
                ToolTip.Tip="Move earlier in the chain"/>

        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" VerticalAlignment="Center"
                   Foreground="{StaticResource CatppuccinMauve}"/>
    </DockPanel>
</UserControl>
