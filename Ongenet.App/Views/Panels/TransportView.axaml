<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Ongenet.App.ViewModels"
             xmlns:controls="using:Ongenet.App.Controls"
             xmlns:audio="using:Ongenet.Core.Audio"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="48"
             x:Class="Ongenet.App.Views.Panels.TransportView"
             x:DataType="vm:TransportViewModel">

    <Border Classes="panel" Padding="12,7">
        <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto">

            <!-- Col 0: transport cluster -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4"
                        VerticalAlignment="Center" Margin="0,0,12,0">
                <controls:IconButton Classes="large success"
                                     Icon="{StaticResource IconPlay}"
                                     Command="{Binding PlayCommand}" IsEnabled="{Binding CanPlay}"
                                     ToolTip.Tip="Play (Space)"/>
                <controls:IconButton Classes="danger"
                                     Icon="{StaticResource IconStop}"
                                     Command="{Binding StopCommand}" IsEnabled="{Binding CanStop}"
                                     ToolTip.Tip="Stop (Space)"/>
                <controls:IconButton Classes="record"
                                     Classes.active="{Binding IsRecording}"
                                     Icon="{StaticResource IconRecord}"
                                     Command="{Binding RecordCommand}" IsEnabled="{Binding CanRecord}"
                                     ToolTip.Tip="Record (one-bar count-in into armed tracks)"/>
            </StackPanel>

            <Border Grid.Column="1" Classes="divider vertical" Margin="0,4,12,4"/>

            <!-- Col 2: time readout + edit-mode/loop tools -->
            <StackPanel Grid.Column="2" Spacing="6" VerticalAlignment="Center" Margin="0,0,12,0">
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <!-- Render-only control (not a TextBlock): the playhead time changes ~30x/sec while
                         playing, and a bound TextBlock re-runs an expensive measure layout each frame. -->
                    <controls:TimeReadoutControl Text="{Binding PlayheadTime}" FontSize="14"
                                                 VerticalAlignment="Center"/>
                    <TextBlock Text="/" VerticalAlignment="Center"
                               Foreground="{StaticResource CatppuccinOverlay1}"/>
                    <TextBlock Classes="mono" Text="{Binding TotalTime}" FontSize="14"
                               VerticalAlignment="Center" Foreground="{StaticResource CatppuccinSubtext0}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <ToggleButton Classes="toggle" IsChecked="{Binding IsSliceMode}"
                                  ToolTip.Tip="Slice mode: click a clip to cut it at the grid — or hold CTRL">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Path Classes="icon small" Data="{StaticResource IconScissors}"/>
                            <TextBlock Text="Slice" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ToggleButton>
                    <controls:IconButton Classes="flat" Icon="{StaticResource IconChevronRight}"
                                         Command="{Binding SetLoopStartCommand}"
                                         ToolTip.Tip="Set loop start to the cursor (Shift+[)"/>
                    <controls:IconButton Classes="flat" Icon="{StaticResource IconChevronLeft}"
                                         Command="{Binding SetLoopEndCommand}"
                                         ToolTip.Tip="Set loop end to the cursor (Shift+])"/>
                    <controls:IconButton Classes="flat active" Icon="{StaticResource IconLoop}"
                                         IsVisible="{Binding IsLooping}" IsHitTestVisible="False"
                                         ToolTip.Tip="Loop region active"/>
                </StackPanel>
            </StackPanel>

            <!-- Centre: tempo + bars + time signature -->
            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8"
                        VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Classes="caption" Text="Tempo" VerticalAlignment="Center"/>
                <NumericUpDown Value="{Binding Bpm}"
                               Minimum="20" Maximum="300" Increment="1"
                               FormatString="0.#" Width="110"
                               VerticalAlignment="Center"/>
                <TextBlock Classes="caption" Text="BPM" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Classes="caption" Text="Bars" VerticalAlignment="Center"/>
                <NumericUpDown Value="{Binding Bars}"
                               Minimum="1" Maximum="999" Increment="1"
                               FormatString="0" Width="120" MinWidth="120"
                               VerticalAlignment="Center"/>

                <TextBlock Classes="caption" Text="Time" VerticalAlignment="Center" Margin="8,0,0,0"/>
                <NumericUpDown Value="{Binding TimeSigNumerator}" Minimum="1" Maximum="32" Increment="1"
                               FormatString="0" Width="100" MinWidth="100" VerticalAlignment="Center"/>
                <TextBlock Text="/" VerticalAlignment="Center" Foreground="{StaticResource CatppuccinSubtext0}"/>
                <ComboBox ItemsSource="{Binding Denominators}" SelectedItem="{Binding TimeSigDenominator}"
                          Width="70" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Col 4: render + master loudness meter (device selection lives in the Settings window) -->
            <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="10"
                        VerticalAlignment="Center" HorizontalAlignment="Right">
                <Button Classes="accent compact" Click="OnRender" IsEnabled="{Binding CanRender}"
                        ToolTip.Tip="Export the arrangement to a WAV file">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Path Classes="icon small" Data="{StaticResource IconExport}"/>
                        <TextBlock Text="Render" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <controls:MasterMeterControl Height="20" MinWidth="200"
                                             LevelLeft="{Binding MasterLevelLeft}"
                                             LevelRight="{Binding MasterLevelRight}"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
